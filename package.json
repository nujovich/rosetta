{
  "name": "@nujovich/rosetta",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Rosetta: estándar abierto + harmonizador de datos de femicidios (Argentina). Motor genérico + adaptadores por fuente.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "fixture": "npm run fixture:rnfja && npm run fixture:rnfja-sentencias && npm run fixture:aqsnv && npm run fixture:lucia-perez && npm run fixture:snic",
    "fixture:rnfja": "tsx scripts/make-fixture.ts",
    "fixture:rnfja-sentencias": "tsx scripts/make-fixture-rnfja-sentencias.ts",
    "fixture:lucia-perez": "tsx scripts/make-fixture-lucia-perez.ts",
    "fixture:aqsnv": "tsx scripts/make-fixture-aqsnv.ts",
    "fixture:snic": "tsx scripts/make-fixture-snic.ts",
    "dev": "tsx src/cli.ts",
    "smoke": "npm run fixture:rnfja && tsx src/cli.ts run rnfja --dir ./fixtures/rnfja-2024 --anio 2024 --out ./out/rnfja-2024.json",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:migrate": "tsx src/cli.ts migrate",
    "db:load": "tsx src/cli.ts load",
    "pretest": "npm run fixture",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "pg": "^8.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
